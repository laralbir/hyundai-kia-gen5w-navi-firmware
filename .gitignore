# Ignorar todo
*

# Excepto estos
!.gitignore
!.claude/
!.claude/**
!docs/
!docs/**
!CLAUDE.md
!README.md
!tools/
!tools/**

# Reignorar basura de ejecución dentro de tools/ (bytecode Python, cachés)
tools/**/__pycache__/
tools/**/*.pyc

# Reignorar artefactos de build de Swift Package Manager / Xcode dentro de tools/
tools/**/.build/
tools/**/.swiftpm/
tools/**/*.xcodeproj/

# Reignorar basura de Finder
tools/**/.DS_Store

# Repos upstream de gen5w clonados por tools/setup.sh — código de terceros con su propio
# historial git y binarios; solo para inspección local, no forman parte de este repo.
tools/navi_extended/
tools/update_decryptor/
tools/update-patcher/
tools/gen5w-docker/
tools/update_fetcher/
